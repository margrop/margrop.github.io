    <item>
      <title>Does Synology DSM Support QEMU Guest Agent?</title>
      <link>https://blog.margrop.net/en/post/is-dsm-supported-qemu-agent/</link>
      <pubDate>Wed, 20 Jan 2021 13:19:28 +0800</pubDate>
